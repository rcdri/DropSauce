		<item name="paddingBottomSystemWindowInsets">false</item>
	</style>

	<style name="Widget.Kotatsu.BottomSheet.DragHandle" parent="Widget.Material3.BottomSheet.DragHandle">
		<!-- Fix weird bottom padding -->
		<item name="android:paddingBottom">0dp</item>
	</style>

	<!-- Expressive details chapters sheet: extra-rounded top + the app surface tone so the pull-up
	     menu reads like the settings/downloads surfaces. -->
	<style name="ShapeAppearanceOverlay.Kotatsu.DetailsSheet" parent="">
		<item name="cornerFamily">rounded</item>
		<item name="cornerSizeTopLeft">32dp</item>
		<item name="cornerSizeTopRight">32dp</item>
		<item name="cornerSizeBottomLeft">0dp</item>
		<item name="cornerSizeBottomRight">0dp</item>
	</style>

	<!-- The sheet's content views are painted ?android:colorBackground at runtime
	     (ChaptersPagesSheet.applyDetailsSheetSurface). The background drawable must use the SAME flat
	     colour with NO elevation overlay, otherwise at full screen the edge-to-edge top inset padding
	     exposes this drawable as a mismatched band across the status bar. Elevation 0 disables the
	     overlay tint so the band stays identical to the content. -->
	<style name="Widget.Kotatsu.BottomSheet.Details" parent="Widget.Material3.BottomSheet.Modal">
		<item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Kotatsu.DetailsSheet</item>
		<item name="backgroundTint">?android:attr/colorBackground</item>
		<item name="android:elevation">0dp</item>
		<item name="paddingBottomSystemWindowInsets">false</item>
	</style>

