	</style>

	<style name="AlertDialog.Kotatsu" parent="MaterialAlertDialog.Material3">
		<item name="backgroundTint">?attr/colorSurface</item>
		<item name="android:background">@drawable/m3_popup_background</item>
		<item name="android:textColor">?attr/colorOnSurface</item>
		<item name="android:textColorPrimary">?attr/colorOnSurface</item>
		<item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
		<item name="android:textColorAlertDialogListItem">?attr/colorOnSurface</item>
