<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/widget_stats_root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_appwidget_root"
	android:orientation="vertical"
	android:padding="12dp"
	android:theme="@style/Theme.Kotatsu.AppWidgetContainer">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:paddingBottom="6dp"
		tools:ignore="UseCompoundDrawables">

		<ImageView
			android:layout_width="14dp"
			android:layout_height="14dp"
			android:src="@drawable/ic_timer"
			android:contentDescription="@null"
			android:tint="@color/kotatsu_onSurface"
			tools:ignore="UseAppTint" />

		<TextView
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginStart="8dp"
			android:layout_weight="1"
			android:ellipsize="end"
			android:maxLines="1"
			android:text="@string/widget_stats"
			android:textColor="@color/kotatsu_onSurface"
			android:textSize="13sp"
			android:textStyle="bold"
			android:letterSpacing="0.02" />
	</LinearLayout>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:layout_marginTop="2dp">

		<TextView
			android:id="@+id/widget_stats_today_value"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:textColor="@color/kotatsu_onSurface"
			android:textSize="26sp"
			android:textStyle="bold"
			android:includeFontPadding="false"
			tools:text="1h 24m" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginStart="10dp"
			android:background="@drawable/bg_appwidget_chip"
			android:paddingHorizontal="10dp"
			android:paddingVertical="3dp"
			android:text="@string/widget_stats_today"
			android:textColor="@color/kotatsu_onPrimaryContainer"
			android:textSize="11sp"
			android:textStyle="bold"
			android:letterSpacing="0.05" />
	</LinearLayout>

	<TextView
		android:id="@+id/widget_stats_subtitle"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="2dp"
		android:textColor="@color/kotatsu_onSurfaceVariant"
		android:textSize="12sp"
		tools:text="3-day streak · 6h 12m this week" />

	<ImageView
		android:id="@+id/widget_stats_chart"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_marginTop="8dp"
		android:layout_weight="1"
		android:contentDescription="@null"
		android:scaleType="fitXY" />

	<LinearLayout
		android:id="@+id/widget_stats_weekdays"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="2dp"
		android:baselineAligned="false"
		android:orientation="horizontal">

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_monday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="M" />
		</FrameLayout>

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_tuesday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="T" />
		</FrameLayout>

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_wednesday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="W" />
		</FrameLayout>

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_thursday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="T" />
		</FrameLayout>

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_friday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="F" />
		</FrameLayout>

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_saturday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="S" />
		</FrameLayout>

		<FrameLayout
			android:layout_width="0dp"
			android:layout_height="24dp"
			android:layout_weight="1">

			<TextView
				android:id="@+id/widget_stats_weekday_sunday"
				style="@style/Widget.Kotatsu.AppWidget.WeekdayLabel"
				android:text="S" />
		</FrameLayout>
	</LinearLayout>
</LinearLayout>
