<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/widget_root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_appwidget_root"
	android:orientation="vertical"
	android:padding="12dp"
	android:theme="@style/Theme.Kotatsu.AppWidgetContainer">

	<LinearLayout
		android:id="@+id/widget_header"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:paddingBottom="8dp">

		<ImageView
			android:layout_width="14dp"
			android:layout_height="14dp"
			android:src="@drawable/ic_heart"
			android:contentDescription="@null"
			android:tint="@color/kotatsu_onSurface"
			tools:ignore="UseAppTint" />

		<TextView
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginStart="8dp"
			android:layout_weight="1"
			android:ellipsize="end"
			android:maxLines="1"
			android:text="@string/widget_favorites"
			android:textColor="@color/kotatsu_onSurface"
			android:textSize="13sp"
			android:textStyle="bold"
			android:letterSpacing="0.02" />

		<ImageView
			android:id="@+id/widget_settings"
			android:layout_width="22dp"
			android:layout_height="22dp"
			android:padding="2dp"
			android:src="@drawable/ic_settings"
			android:contentDescription="@string/widget_favorites_configure" />
	</LinearLayout>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:baselineAligned="false"
		android:gravity="center"
		android:orientation="horizontal">

		<FrameLayout
			android:id="@+id/widget_slot_1"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_marginEnd="6dp"
			android:layout_weight="1"
			tools:ignore="NestedWeights">

			<ImageView
				android:id="@+id/widget_cover_1"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@drawable/bg_appwidget_cover"
				android:scaleType="fitXY"
				android:contentDescription="@string/widget_cover_content_description"
				tools:src="@color/kotatsu_surfaceContainerHigh" />

			<ImageView
				android:id="@+id/widget_placeholder_1"
				android:layout_width="32dp"
				android:layout_height="32dp"
				android:layout_gravity="center"
				android:src="@drawable/ic_add"
				android:visibility="gone"
				android:contentDescription="@null"
				app:tint="@color/kotatsu_onSurfaceVariant" />
		</FrameLayout>

		<FrameLayout
			android:id="@+id/widget_slot_2"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_marginHorizontal="6dp"
			android:layout_weight="1">

			<ImageView
				android:id="@+id/widget_cover_2"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@drawable/bg_appwidget_cover"
				android:scaleType="fitXY"
				android:contentDescription="@string/widget_cover_content_description"
				tools:src="@color/kotatsu_surfaceContainerHigh" />

			<ImageView
				android:id="@+id/widget_placeholder_2"
				android:layout_width="32dp"
				android:layout_height="32dp"
				android:layout_gravity="center"
				android:src="@drawable/ic_add"
				android:visibility="gone"
				android:contentDescription="@null"
				app:tint="@color/kotatsu_onSurfaceVariant" />
		</FrameLayout>

		<FrameLayout
			android:id="@+id/widget_slot_3"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_marginStart="6dp"
			android:layout_weight="1">

			<ImageView
				android:id="@+id/widget_cover_3"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@drawable/bg_appwidget_cover"
				android:scaleType="fitXY"
				android:contentDescription="@string/widget_cover_content_description"
				tools:src="@color/kotatsu_surfaceContainerHigh" />

			<ImageView
				android:id="@+id/widget_placeholder_3"
				android:layout_width="32dp"
				android:layout_height="32dp"
				android:layout_gravity="center"
				android:src="@drawable/ic_add"
				android:visibility="gone"
				android:contentDescription="@null"
				app:tint="@color/kotatsu_onSurfaceVariant" />
		</FrameLayout>
	</LinearLayout>

	<TextView
		android:id="@+id/widget_empty_hint"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_gravity="center_horizontal"
		android:layout_marginTop="8dp"
		android:text="@string/widget_favorites_empty"
		android:textColor="@color/kotatsu_onSurfaceVariant"
		android:textSize="11sp"
		android:visibility="gone"
		tools:visibility="visible" />
</LinearLayout>
