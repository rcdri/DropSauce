<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_appwidget_root"
	android:gravity="center_vertical"
	android:orientation="horizontal"
	android:padding="10dp"
	android:theme="@style/Theme.Kotatsu.AppWidgetContainer">

	<ImageView
		android:id="@+id/widget_cover"
		android:layout_width="48dp"
		android:layout_height="match_parent"
		android:background="@drawable/bg_appwidget_cover"
		android:scaleType="fitXY"
		android:contentDescription="@string/widget_cover_content_description"
		tools:src="@color/kotatsu_surfaceContainerHigh" />

	<LinearLayout
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="10dp"
		android:layout_weight="1"
		android:orientation="vertical">

		<TextView
			android:id="@+id/widget_title"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:ellipsize="end"
			android:maxLines="2"
			android:textColor="@color/kotatsu_onSurface"
			android:textSize="13sp"
			android:textStyle="bold"
			tools:text="Manga Title" />

		<ProgressBar
			android:id="@+id/widget_progress"
			style="?android:attr/progressBarStyleHorizontal"
			android:layout_width="match_parent"
			android:layout_height="3dp"
			android:layout_marginTop="6dp"
			android:max="100"
			android:progress="40"
			android:progressDrawable="@drawable/bg_appwidget_progress" />
	</LinearLayout>

	<ImageView
		android:id="@+id/widget_cta"
		android:layout_width="40dp"
		android:layout_height="40dp"
		android:layout_marginStart="8dp"
		android:background="@drawable/bg_appwidget_button_round"
		android:padding="10dp"
		android:src="@drawable/ic_play"
		android:contentDescription="@string/widget_continue_reading_open"
		android:tint="@color/kotatsu_onPrimary"
		tools:ignore="UseAppTint" />
</LinearLayout>
