<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context=".main.ui.MainActivity">

	<androidx.fragment.app.FragmentContainerView
		android:id="@id/container"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"
		tools:layout="@layout/fragment_list" />

	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/appbar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@null"
		android:clipToPadding="false"
		android:elevation="0dp"
		android:fitsSystemWindows="false"
		android:stateListAnimator="@null"
		app:elevation="0dp"
		app:liftOnScroll="false"
		app:liftOnScrollColor="@null"
		app:materialThemeOverlay="@style/ThemeOverlay.Kotatsu.AppBarWithSearch"
		app:statusBarForeground="?attr/colorSurface">

		<org.koitharu.kotatsu.core.ui.widgets.WindowInsetHolder
			android:id="@+id/insetsHolder"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="top"
			android:fitsSystemWindows="true"
			app:layout_scrollFlags="scroll|enterAlways|snap" />

		<LinearLayout
			android:id="@+id/layout_search"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center_horizontal"
			android:maxWidth="600dp"
			android:orientation="horizontal"
			android:gravity="center_vertical"
			android:clipToPadding="false"
			android:paddingHorizontal="4dp"
			app:layout_scrollFlags="scroll|enterAlways|snap">

			<FrameLayout
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:layout_marginEnd="8dp"
				android:clipChildren="false"
				android:clipToPadding="false">

				<com.google.android.material.button.MaterialButton
					android:id="@+id/button_overflow"
					style="?materialIconButtonStyle"
					android:layout_width="48dp"
					android:layout_height="48dp"
					android:padding="0dp"
					android:insetTop="0dp"
					android:insetBottom="0dp"
					android:insetLeft="0dp"
					android:insetRight="0dp"
					app:icon="@drawable/ic_more_vert"
					app:iconSize="24dp"
					app:iconPadding="0dp"
					app:iconGravity="textStart"
					app:iconTint="?attr/colorOnSurfaceVariant"
					android:contentDescription="@string/more" />

			</FrameLayout>

			<com.google.android.material.search.SearchBar
				android:id="@+id/search_bar"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:layout_marginEnd="8dp"
				android:hint="@string/search_manga"
				app:hideNavigationIcon="true"
				app:forceDefaultNavigationOnClickListener="false" />

			<FrameLayout
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:clipChildren="false"
				android:clipToPadding="false">

				<com.google.android.material.button.MaterialButton
					android:id="@+id/button_settings"
					style="?materialIconButtonStyle"
					android:layout_width="48dp"
					android:layout_height="48dp"
					android:padding="0dp"
					android:insetTop="0dp"
					android:insetBottom="0dp"
					android:insetLeft="0dp"
					android:insetRight="0dp"
					app:icon="@drawable/ic_settings"
					app:iconSize="24dp"
					app:iconPadding="0dp"
					app:iconGravity="textStart"
					app:iconTint="?attr/colorOnSurfaceVariant"
					android:contentDescription="@string/settings" />

				<View
					android:id="@+id/badge_settings_update"
					android:layout_width="9dp"
					android:layout_height="9dp"
					android:layout_gravity="top|end"
					android:layout_marginTop="12dp"
					android:layout_marginEnd="11dp"
					android:background="@drawable/bg_update_dot"
					android:backgroundTint="?attr/colorError"
					android:visibility="gone"
					tools:visibility="visible"
					android:contentDescription="@string/app_update_available" />

			</FrameLayout>

		</LinearLayout>

	</com.google.android.material.appbar.AppBarLayout>

	<com.google.android.material.search.SearchView
		android:id="@+id/search_view"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:hint="@string/search_hint"
		app:hideNavigationIcon="false"
		app:layout_anchor="@id/search_bar">

		<androidx.recyclerview.widget.RecyclerView
			android:id="@+id/recyclerView_search"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:clipToPadding="false"
			android:orientation="vertical"
			android:scrollbars="vertical"
			app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

	</com.google.android.material.search.SearchView>

	<com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
		android:id="@+id/fab"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginHorizontal="16dp"
		android:text="@string/_continue"
		android:visibility="gone"
		app:icon="@drawable/ic_read"
		app:layout_anchor="@id/bottomNav"
		app:layout_anchorGravity="top|end"
		app:layout_behavior="org.koitharu.kotatsu.main.ui.MainActionButtonBehavior"
		app:layout_dodgeInsetEdges="bottom"
		app:layout_insetEdge="bottom"
		tools:ignore="InconsistentLayout"
		tools:visibility="visible" />

	<org.koitharu.kotatsu.core.ui.widgets.FloatingBottomNavigationView
		android:id="@+id/bottomNav"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_gravity="bottom"
		android:background="@android:color/transparent"
		android:fitsSystemWindows="false" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
