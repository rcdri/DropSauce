<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom-up dark gradient drawn over a manga cover so the overlaid title stays legible. -->
<shape
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:shape="rectangle">
	<gradient
		android:angle="90"
		android:centerColor="#73000000"
		android:centerY="0.55"
		android:endColor="@android:color/transparent"
		android:startColor="#D9000000"
		android:type="linear" />
</shape>
